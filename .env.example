# Sovereign AI - Environment Variables
# Copy to .env and fill in your values

# ── LLM — Provider selection ──────────────────────────────────────────────────
# Each tier can use a different provider. Valid values:
#   anthropic | openai | gemini | groq | openrouter | ollama | custom
#
# Example — all tiers on OpenAI (default):
#   LLM_TIER1_PROVIDER=openai      LLM_TIER1_MODEL=gpt-4o-mini
#   LLM_TIER2_PROVIDER=openai      LLM_TIER2_MODEL=gpt-4o
#   LLM_TIER3_PROVIDER=openai      LLM_TIER3_MODEL=gpt-4o
#
# Example — mix: local Ollama for Tier 1, Groq for Tier 2, Anthropic for Tier 3:
#   LLM_TIER1_PROVIDER=ollama      LLM_TIER1_MODEL=llama3.2
#   LLM_TIER2_PROVIDER=groq        LLM_TIER2_MODEL=llama-3.3-70b-versatile
#   LLM_TIER3_PROVIDER=anthropic   LLM_TIER3_MODEL=claude-sonnet-4-6
#
LLM_TIER1_PROVIDER=openai
LLM_TIER2_PROVIDER=openai
LLM_TIER3_PROVIDER=openai

# ── LLM — Anthropic ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── LLM — OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for Azure or other compat APIs

# ── LLM — Google Gemini ───────────────────────────────────────────────────────
GEMINI_API_KEY=
# Uses Google's OpenAI-compatible endpoint — no extra SDK needed.
# Recommended models: gemini-2.0-flash, gemini-1.5-pro

# ── LLM — Groq ────────────────────────────────────────────────────────────────
GROQ_API_KEY=
# Recommended models: llama-3.3-70b-versatile, mixtral-8x7b-32768

# ── LLM — OpenRouter ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# Supports any model from https://openrouter.ai/models

# ── LLM — Ollama (local / self-hosted) ────────────────────────────────────────
# No API key required. Override base URL when running inside Docker.
# OLLAMA_BASE_URL=http://ollama:11434/v1   # Docker service name
# OLLAMA_BASE_URL=http://localhost:11434/v1  # host machine (default)

# ── LLM — Custom OpenAI-compatible endpoint ────────────────────────────────────
# CUSTOM_LLM_BASE_URL=http://my-llm-server:8080/v1
# CUSTOM_LLM_API_KEY=

# ── Databases ─────────────────────────────────────────────────
NEO4J_PASSWORD=sovereign2026
POSTGRES_PASSWORD=sovereign2026

# ── Observability ─────────────────────────────────────────────
GRAFANA_PASSWORD=sovereign2026

# ── Audit Access Control (RBAC) ───────────────────────────────
# All keys empty = development mode (no auth required).
# AUDIT_API_KEY is the legacy all-access key (treated as admin if set).
# Use role-segregated keys in production for least-privilege access.
AUDIT_API_KEY=

# Auditor:          GET /api/audit/logs, /replay/*, /verify-chain
AUDIT_KEY_AUDITOR=
# Security Officer: all Auditor endpoints + GET /api/audit/security-events
AUDIT_KEY_SECURITY_OFFICER=
# Admin:            full access (use for automated system operations)
AUDIT_KEY_ADMIN=

# ── Model Governance ──────────────────────────────────────────
# Secure mode: forces temperature=0.0, minimum TIER_2 routing.
# Set to true for official/production government deployments.
SECURE_MODE=false

# ── Deployment Mode ────────────────────────────────────────────
# "connected": LLM API enabled (default, requires ANTHROPIC_API_KEY)
# "airgapped": LLM API blocked, deterministic eligibility engine only
#   For airgapped deployment use the compose overlay instead:
#   docker compose -f docker-compose.yml -f docker-compose.airgapped.yml up -d
MODE=connected

# ── Field Encryption ──────────────────────────────────────────
# Encrypts user_query and response_preview at rest (AES-128 via Fernet).
# Leave empty for development (plaintext stored, no behaviour change).
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotation:  FIELD_ENCRYPTION_KEY=<new_key>,<old_key>
FIELD_ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins for the browser API.
# Default covers OpenWebUI on port 3000 and standard dev ports.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
