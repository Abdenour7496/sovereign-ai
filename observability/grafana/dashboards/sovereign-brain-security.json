{
  "title": "Sovereign Brain \u2014 Security Dashboard",
  "uid": "sovereign-security-v1",
  "version": 1,
  "schemaVersion": 37,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Critical Events (24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(sovereign_security_events_total{severity=\"critical\"}[24h]))",
          "legendFormat": "Critical"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Jailbreak Attempts (24h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(sovereign_security_events_total{event_type=\"jailbreak_attempt\"}[24h]))",
          "legendFormat": "Jailbreaks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Unauthorized Access (24h)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(sovereign_security_events_total{event_type=\"audit_unauthorized_access\"}[24h]))",
          "legendFormat": "Unauthorized"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Chain Breaks (Total)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sovereign_audit_chain_breaks_total",
          "legendFormat": "Breaks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Egress Blocked (24h)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(sovereign_security_events_total{event_type=\"egress_attempt_blocked\"}[24h]))",
          "legendFormat": "Blocked"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "High+Critical Events (24h)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(sovereign_security_events_total{severity=~\"high|critical\"}[24h]))",
          "legendFormat": "High+Critical"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Security Events by Severity",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 14, "h": 8 },
      "targets": [
        { "expr": "sum(rate(sovereign_security_events_total{severity=\"critical\"}[5m]))", "legendFormat": "Critical" },
        { "expr": "sum(rate(sovereign_security_events_total{severity=\"high\"}[5m]))", "legendFormat": "High" },
        { "expr": "sum(rate(sovereign_security_events_total{severity=\"medium\"}[5m]))", "legendFormat": "Medium" },
        { "expr": "sum(rate(sovereign_security_events_total{severity=\"low\"}[5m]))", "legendFormat": "Low" },
        { "expr": "sum(rate(sovereign_security_events_total{severity=\"info\"}[5m]))", "legendFormat": "Info" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "High" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Medium" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Low" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Info" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 8,
      "title": "Attack Vector Breakdown (24h)",
      "type": "piechart",
      "gridPos": { "x": 14, "y": 4, "w": 10, "h": 8 },
      "targets": [
        { "expr": "sum(increase(sovereign_security_events_total{event_type=\"jailbreak_attempt\"}[24h]))", "legendFormat": "Jailbreak" },
        { "expr": "sum(increase(sovereign_security_events_total{event_type=\"prompt_injection\"}[24h]))", "legendFormat": "Prompt Injection" },
        { "expr": "sum(increase(sovereign_security_events_total{event_type=\"system_probe\"}[24h]))", "legendFormat": "System Probe" },
        { "expr": "sum(increase(sovereign_security_events_total{event_type=\"role_override\"}[24h]))", "legendFormat": "Role Override" },
        { "expr": "sum(increase(sovereign_security_events_total{event_type=\"override_attempt\"}[24h]))", "legendFormat": "Override Attempt" },
        { "expr": "sum(increase(sovereign_security_events_total{event_type=\"data_extraction\"}[24h]))", "legendFormat": "Data Extraction" }
      ]
    },
    {
      "id": 9,
      "title": "Boundary Violations Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(sovereign_security_events_total{event_type=\"jailbreak_attempt\"}[10m]))", "legendFormat": "Jailbreak" },
        { "expr": "sum(rate(sovereign_security_events_total{event_type=\"prompt_injection\"}[10m]))", "legendFormat": "Prompt Injection" },
        { "expr": "sum(rate(sovereign_security_events_total{event_type=\"override_attempt\"}[10m]))", "legendFormat": "Override Attempt" },
        { "expr": "sum(rate(sovereign_security_events_total{event_type=\"role_delimiter_injection\"}[10m]))", "legendFormat": "Delimiter Injection" }
      ]
    },
    {
      "id": 10,
      "title": "Audit Access Activity",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(sovereign_security_events_total{event_type=\"audit_logs_accessed\"}[5m]))", "legendFormat": "Logs Accessed" },
        { "expr": "sum(rate(sovereign_security_events_total{event_type=\"audit_replay_accessed\"}[5m]))", "legendFormat": "Replay Used" },
        { "expr": "sum(rate(sovereign_security_events_total{event_type=\"audit_unauthorized_access\"}[5m]))", "legendFormat": "Unauthorized Access" },
        { "expr": "sum(rate(sovereign_security_events_total{event_type=\"audit_chain_verified\"}[5m]))", "legendFormat": "Chain Verified" }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Unauthorized Access" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 11,
      "title": "Egress Monitoring",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(sovereign_security_events_total{event_type=\"egress_request_sent\"}[5m]))", "legendFormat": "Outbound Sent (connected)" },
        { "expr": "sum(rate(sovereign_security_events_total{event_type=\"egress_attempt_blocked\"}[5m]))", "legendFormat": "Outbound BLOCKED (airgapped)" }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Outbound BLOCKED (airgapped)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 12,
      "title": "Active Security Alerts",
      "type": "alertlist",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": ["alertname"],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {
          "error": true,
          "firing": true,
          "noData": false,
          "normal": false,
          "pending": true
        }
      }
    },
    {
      "id": 13,
      "title": "Behavioral Anomalies",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum by (anomaly_type) (rate(sovereign_anomalies_total[5m]))",
          "legendFormat": "{{anomaly_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 14,
      "title": "Chain Anchor Age",
      "type": "stat",
      "gridPos": { "x": 12, "y": 28, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "time() - sovereign_chain_anchor_last_timestamp_seconds",
          "legendFormat": "Seconds since last anchor"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7200 },
              { "color": "red", "value": 86400 }
            ]
          }
        }
      }
    },
    {
      "id": 15,
      "title": "Dual-Control Activity (24h)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 28, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "increase(sovereign_dual_control_requests_total[24h])",
          "legendFormat": "Requests"
        },
        {
          "expr": "increase(sovereign_dual_control_approvals_total[24h])",
          "legendFormat": "Approvals"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue", "value": 1 }
            ]
          }
        }
      }
    }
  ]
}
