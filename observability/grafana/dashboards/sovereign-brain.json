{
  "title": "Sovereign Brain — AI Governance Dashboard",
  "uid": "sovereign-brain-v1",
  "version": 1,
  "schemaVersion": 37,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests (24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(increase(sovereign_requests_total[24h]))",
        "legendFormat": "Requests"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color": "green", "value": null}] } } }
    },
    {
      "id": 2,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sovereign_active_requests",
        "legendFormat": "Active"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "title": "Avg Response Latency (p50)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.5, rate(sovereign_request_latency_seconds_bucket[5m]))",
        "legendFormat": "p50 latency"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Hallucination Guard Triggers",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "increase(sovereign_hallucination_guard_total[24h])",
        "legendFormat": "Guard triggers"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 5},
          {"color": "red", "value": 20}
        ]} } }
    },
    {
      "id": 5,
      "title": "Requests by Tier (Rate)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(sovereign_requests_total{tier='TIER_1'}[5m])", "legendFormat": "Tier 1 — Haiku (simple)" },
        { "expr": "rate(sovereign_requests_total{tier='TIER_2'}[5m])", "legendFormat": "Tier 2 — Sonnet (medium)" },
        { "expr": "rate(sovereign_requests_total{tier='TIER_3'}[5m])", "legendFormat": "Tier 3 — Opus (complex)" }
      ]
    },
    {
      "id": 6,
      "title": "Complexity Score Distribution",
      "type": "histogram",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(sovereign_complexity_score_bucket[5m])",
        "legendFormat": "Complexity"
      }]
    },
    {
      "id": 7,
      "title": "Eligibility Outcomes",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "targets": [
        { "expr": "sum(increase(sovereign_eligibility_checks_total{result='eligible'}[24h]))", "legendFormat": "Eligible" },
        { "expr": "sum(increase(sovereign_eligibility_checks_total{result='not_eligible'}[24h]))", "legendFormat": "Not Eligible" }
      ]
    },
    {
      "id": 8,
      "title": "RAG Retrieval Confidence",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 12, "w": 16, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(sovereign_retrieval_confidence_bucket[5m]))", "legendFormat": "p50 confidence" },
        { "expr": "histogram_quantile(0.9, rate(sovereign_retrieval_confidence_bucket[5m]))", "legendFormat": "p90 confidence" }
      ]
    },
    {
      "id": 9,
      "title": "Request Latency by Tier (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(sovereign_request_latency_seconds_bucket{tier='TIER_1'}[5m]))", "legendFormat": "Tier 1 p95" },
        { "expr": "histogram_quantile(0.95, rate(sovereign_request_latency_seconds_bucket{tier='TIER_2'}[5m]))", "legendFormat": "Tier 2 p95" },
        { "expr": "histogram_quantile(0.95, rate(sovereign_request_latency_seconds_bucket{tier='TIER_3'}[5m]))", "legendFormat": "Tier 3 p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
